{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EvaluationOutputSchema",
  "description": "Schema for evaluation run outputs/predictions.",
  "type": "object",
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this evaluation run."
    },
    "dataset_id": {
      "type": "string",
      "description": "Identifier of the evaluation dataset used."
    },
    "model_id": {
      "type": "string",
      "description": "Identifier of the model evaluated."
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "query_id": {
            "type": "string",
            "description": "Identifier for the matched test case query."
          },
          "generated_answer": {
            "type": "string",
            "description": "The textual answer generated by the model."
          },
          "retrieved_document_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of document identifiers retrieved by the system, in order."
          },
          "cited_document_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of document identifiers cited in the generated answer."
          },
          "ttft": {
            "type": "number",
            "description": "Time to first token in seconds (optional)."
          },
          "throughput": {
            "type": "number",
            "description": "Throughput in tokens per second (optional)."
          }
        },
        "required": ["query_id", "generated_answer", "retrieved_document_ids", "cited_document_ids"],
        "additionalProperties": false
      },
      "description": "List of outputs corresponding to the test cases."
    }
  },
  "required": ["run_id", "dataset_id", "model_id", "results"],
  "additionalProperties": false
}
